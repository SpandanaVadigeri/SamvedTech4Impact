# ==================== SERVER CONFIGURATION ====================
NODE_ENV=development
PORT=3000
HOST=localhost

# ==================== DATABASE CONFIGURATION ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solapur_safety
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=20

# ==================== JWT CONFIGURATION ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2026
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# ==================== REDIS CONFIGURATION (for caching) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== MQTT CONFIGURATION (for IoT) ====================
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ==================== EMAIL CONFIGURATION (for alerts) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@solapur.gov.in
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=control@solapur.gov.in

# ==================== SMS CONFIGURATION (for emergency) ====================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
EMERGENCY_PHONE=+919876543210

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=combined.log
ERROR_LOG_FILE=error.log

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ==================== SYNC CONFIGURATION ====================
SYNC_BATCH_SIZE=1000
SYNC_MAX_AGE_DAYS=30
OFFLINE_DATA_RETENTION_DAYS=90

# ==================== THRESHOLDS (matching Flutter app) ====================
H2S_CAUTION=5.0
H2S_BLOCK=10.0
CH4_CAUTION=0.5
CH4_BLOCK=2.0
CO_CAUTION=25.0
CO_BLOCK=35.0
O2_CAUTION=20.8
O2_BLOCK=19.5

# ==================== ALERT ESCALATION TIMINGS (seconds) ====================
ESCALATION_LEVEL1=5
ESCALATION_LEVEL2=10
ESCALATION_LEVEL3=15

# ==================== API KEYS ====================
GOOGLE_MAPS_API_KEY=your-google-maps-key
OPENWEATHER_API_KEY=your-openweather-key

# ==================== FEATURE FLAGS ====================
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_OFFLINE_SYNC=true
ENABLE_EMERGENCY_SMS=true

# ==================== SECURITY ====================
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
SESSION_SECRET=session-secret-key-change-this

# ==================== FILE UPLOAD ====================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ==================== EXTERNAL SERVICES ====================
ML_SERVICE_URL=http://localhost:5001
DASHBOARD_URL=http://localhost:5000

# ==================== CLUSTER MODE (for production) ====================
CLUSTER_WORKERS=4

# ==================== METRICS ====================
ENABLE_METRICS=true
METRICS_PORT=9090

# ==================== DEVELOPMENT ONLY ====================
# Remove these in production!
DEV_MODE=true
DEV_SKIP_AUTH=false
DEV_USER_ID=11111111-1111-1111-1111-111111111111